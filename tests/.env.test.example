# =============================================================================
# Test LLM configuration: Qwen API (qwen-flash)
# =============================================================================
# Key is read from system env: DASHSCOPE_API_KEY (no need to set LLM_API_KEY here).
# Optional: copy to .env.test to override provider/model; do not commit .env.test with secrets.

LLM_PROVIDER=qwen
FAIRIFIER_LLM_MODEL=qwen-flash

# Qwen/DashScope API key: set in environment as DASHSCOPE_API_KEY (or LLM_API_KEY)

# Optional: override base URL (default DashScope compatible endpoint)
# QWEN_API_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Optional: keep consistent for reproducible tests
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096
LLM_ENABLE_THINKING=false

# Disable mem0 for tests unless explicitly testing memory (avoids Ollama/Qdrant)
MEM0_ENABLED=false
