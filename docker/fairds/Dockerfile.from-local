# Build when you have a local `fairds.jar` next to this file (e.g. after `docker/pack-fairds-jar.sh`).
# Large JARs are gitignored; use this Dockerfile for offline or dev-channel JARs.
FROM eclipse-temurin:17-jre-jammy

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY fairds.jar /app/fairds.jar

EXPOSE 8083

ENV JAVA_TOOL_OPTIONS="-Xmx2g"

CMD ["java", "-jar", "/app/fairds.jar", "--server.port=8083"]
