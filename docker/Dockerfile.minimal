# ==============================================================================
# FAIRiAgent Minimal Core Dockerfile
# ==============================================================================
# This image contains ONLY the core FAIRiAgent logic, avoiding heavy browser 
# binaries (Playwright) or local database servers. It is designed to be 
# highly compatible with external orchestrators (like docker-compose) where 
# tools like MinerU, Qdrant, and BioContainers run as separate microservices.
# ==============================================================================

FROM python:3.11-slim AS builder

WORKDIR /app

# 1. Install lightweight system dependencies required to build Python packages
# (gcc/g++) and for container health checks (curl).
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    g++ \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 2. Environment constraints for a minimal, clean build
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

# 3. Dependency Layer
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# ==============================================================================
# Production Image
# ==============================================================================
FROM python:3.11-slim

WORKDIR /app

# Copy the compiled Python environment from the builder
COPY --from=builder /usr/local/lib/python3.11/site-packages/ /usr/local/lib/python3.11/site-packages/
COPY --from=builder /usr/local/bin/ /usr/local/bin/

# Install the absolute minimum runtime dependencies
# Docker CLI is installed so the container can spawn BioContainers on the host 
# via a mounted /var/run/docker.sock volume.
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    docker.io \
    && rm -rf /var/lib/apt/lists/*

# 4. Copy Core FAIRiAgent Code
COPY fairifier/ ./fairifier/
COPY kb/ ./kb/
COPY run_fairifier.py .

# Create output and log dirs
RUN mkdir -p output logs

# 5. Define standard API port
EXPOSE 8000

# Provide the flexibility to either serve the API or run CLI commands
ENTRYPOINT ["python", "run_fairifier.py"]
# Default to checking the config info
CMD ["config-info"]
